---
// HBL App のデータ定義
const hblApps = [
  {
    title: "BadAppleNX",
    description: "試しに作ったNintendo SwitchのHome Brew Launcherで動作するソフトです。Bad Apple!!の影絵がSDLで描画されます。",
    image: "https://img.youtube.com/vi/R6-2VF4Oic8/maxresdefault.jpg",
    github: "https://github.com/enupi/BadAppleNX",
    youtube: "https://youtu.be/R6-2VF4Oic8",
  },
];

// M.U.G.E.Nキャラ のデータ定義
const mugenCharacters = [
  {
    name: "りさじゅう",
    image: "/src/assets/risaju.png",
    progress: 0.5,
    lastUpdated: "2025.12.22",
    twitter: "https://x.com/np_mugen",
  },
];
---

<div class="mt-8">
  <h2 class="text-3xl font-bold border-b border-zinc-700 pb-2 mb-8 text-white/90">Release</h2>
  
  <!-- HBL App Section -->
  <div class="mb-16">
    <h3 class="text-2xl font-semibold mb-6 text-blue-400 flex items-center gap-2">
      <span class="w-2 h-2 bg-blue-400 rounded-full"></span>
      HBL App
    </h3>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {hblApps.map((app) => (
        <div class="bg-zinc-900/50 border border-zinc-800 rounded-xl overflow-hidden hover:border-zinc-600 transition-colors">
          <img src={app.image} alt={app.title} class="w-full aspect-video object-cover opacity-80 hover:opacity-100 transition-opacity" />
          <div class="p-5">
                <h4 class="text-2xl font-bold text-white mb-2">{app.title}</h4>
            <p class="text-sm text-zinc-400 mb-6 line-clamp-2 leading-relaxed">{app.description}</p>
            <div class="flex gap-3">
              <a href={app.github} target="_blank" class="text-xs bg-zinc-800 hover:bg-zinc-700 text-white py-2 px-4 rounded-md transition-colors flex items-center gap-2">
                GitHub
              </a>
              <a href={app.youtube} target="_blank" class="text-xs bg-red-900/30 hover:bg-red-900/50 text-red-200 py-2 px-4 rounded-md transition-colors flex items-center gap-2 border border-red-900/50">
                YouTube
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- M.U.G.E.Nキャラ Section -->
  <div>
    <h3 class="text-2xl font-semibold mb-6 text-purple-400 flex items-center gap-2">
      <span class="w-2 h-2 bg-purple-400 rounded-full"></span>
      M.U.G.E.Nキャラ
    </h3>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4">
      {mugenCharacters.map((char) => (
        <div class="bg-zinc-900/50 border border-zinc-800 rounded-xl overflow-hidden hover:border-zinc-600 transition-colors">
          <img src={char.image} alt={char.name} class="w-full aspect-[3/4] object-cover object-top opacity-80 hover:opacity-100 transition-opacity" />
          <div class="p-3">
            <div class="text-[10px] text-purple-400/80 font-mono mb-1 tracking-widest uppercase">
              Updated: {char.lastUpdated}
            </div>
            <h4 class="text-base font-bold text-white mb-3 truncate">{char.name}</h4>
            
            <div class="space-y-2">
              <div class="flex justify-between text-xs text-zinc-400 mb-1">
                <span>Progress</span>
                <span>{char.progress}%</span>
              </div>
              <div class="w-full bg-zinc-800 h-1.5 rounded-full overflow-hidden">
                <div class="bg-gradient-to-r from-purple-600 to-blue-500 h-full rounded-full transition-all duration-1000" style={`width: ${char.progress}%`}></div>
              </div>
            </div>
            <a href={char.twitter} target="_blank" class="mt-4 flex items-center justify-center gap-1.5 text-[10px] bg-[#1DA1F2]/10 hover:bg-[#1DA1F2]/20 text-[#1DA1F2] py-1.5 rounded-md transition-colors border border-[#1DA1F2]/20">進捗報告</a>
          </div>
        </div>
      ))}
    </div>
  </div>
</div>