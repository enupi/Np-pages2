---
---
<button
  id="theme-toggle"
  class="p-2 rounded-lg bg-zinc-100 dark:bg-zinc-800 hover:ring-2 ring-blue-400 transition-all"
  aria-label="Toggle Theme"
>
  <!-- Sun Icon (Visible in dark mode) -->
  <svg id="theme-toggle-dark-icon" class="hidden w-5 h-5 text-yellow-500" fill="currentColor" viewBox="0 0 20 20">
    <path d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z"></path>
  </svg>
  <!-- Moon Icon (Visible in light mode) - Heroicons -->
  <svg id="theme-toggle-light-icon" class="hidden w-5 h-5 text-zinc-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12.79A9 9 0 0112.21 3a9 9 0 100 18 9 9 0 008.79-8.21z" />
  </svg>
</button>

<script>
  const initThemeToggle = () => {
    const themeToggleDarkIcon = document.getElementById('theme-toggle-dark-icon');
    const themeToggleLightIcon = document.getElementById('theme-toggle-light-icon');
    const themeToggleBtn = document.getElementById('theme-toggle');

    if (!themeToggleBtn) return;

    // 二重登録を防止するためのガード
    if (themeToggleBtn.dataset.initialized) return;

    // Layout.astroのインラインスクリプトによって設定された現在のテーマをアイコンに反映
    const isDark = document.documentElement.classList.contains('dark');
    if (isDark) {
      themeToggleDarkIcon?.classList.remove('hidden');
      themeToggleLightIcon?.classList.add('hidden');
    } else {
      themeToggleLightIcon?.classList.remove('hidden');
      themeToggleDarkIcon?.classList.add('hidden');
    }

    themeToggleBtn.addEventListener('click', () => {
      const willBeDark = document.documentElement.classList.toggle('dark');
      localStorage.setItem('theme', willBeDark ? 'dark' : 'light');
      
      themeToggleDarkIcon?.classList.toggle('hidden', !willBeDark);
      themeToggleLightIcon?.classList.toggle('hidden', willBeDark);
    });

    themeToggleBtn.dataset.initialized = 'true';
  };

  // astro:page-load は初回ロード時と遷移時の両方で発火するため、これ1つで十分です
  document.addEventListener('astro:page-load', initThemeToggle);
</script>