---
type Props = {
  title: string;
  full_screen?: boolean;
  className?: string;
  id?: string;
};
const { title = "Section", full_screen = false, className = "", id } = Astro.props;

const sectionId = id || title.toLowerCase().replaceAll(" ", "");
---

<section
  id={sectionId}
  class={`${full_screen ? "h-screen" : ""} py-10 w-full overflow-x-hidden ${className}`}
>
  <div class="max-w-6xl mx-auto px-6 sm:px-10">
    <div class="w-full grid place-items-center">
      <h2 class="text-4xl md:text-6xl text-center text-zinc-900 dark:text-white">{`<${title} />`}</h2>
    </div>
    <div class="w-full mt-10">
      <slot />
    </div>
  </div>
</section>
