---
import { getCollection } from "astro:content";
import BlogPostCard from "@/components/BlogPostCard.astro";
import Section from "@/components/Section.astro";
import Layout from "@/layouts/Layout.astro";
import Parser from "rss-parser";

// 記事データの型を定義
interface NotePost {
  id: string;
  data: {
    title: string;
    description: string;
    pubDate: Date;
  };
}

const parser = new Parser();
const NOTE_RSS_URL = "https://note.com/np7096/rss";

let posts: NotePost[] = [];

/*
try {
  const feed = await parser.parseURL(NOTE_RSS_URL);
  posts = feed.items
    .filter(item => item.link && item.title && item.pubDate)
    .map(item => ({
      id: item.link!, // noteの記事URL
      data: {
        title: item.title!,
        description: item.contentSnippet?.slice(0, 100) + "...", // 冒頭100文字
        pubDate: new Date(item.pubDate!),
      }
    }));
} catch (error) {
  console.error("noteのデータ取得に失敗しました:", error);
}
*/

try {
  const feed = await parser.parseURL(NOTE_RSS_URL);
  posts = feed.items.map((item) => ({
    id: item.link ?? "",
    data: {
      title: item.title ?? "無題",
      description: item.contentSnippet?.replace(/\n/g, " ").slice(0, 150) ?? "", 
      pubDate: item.pubDate ? new Date(item.pubDate) : new Date(),
    }
  })).sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()); // 新しい順にソート
} catch (e) {
  console.error(e);
}
---

<Layout title="Blog">
<!--  <Section title="My Blog Posts">
    <div class="w-full grid grid-cols-1 md:grid-cols-2 gap-4">
      {
        posts.map((post) => (
          <BlogPostCard
