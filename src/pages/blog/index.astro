          />
        ))
      }
    </div>
  </Section>
-->

<main class="max-w-4xl mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold mb-8 text-white">Blog Posts</h1>

    <div class="mb-10">
      <input 
        type="text" 
        id="search-bar" 
        placeholder="記事を検索..." 
        class="w-full p-3 rounded-lg bg-zinc-900 border border-zinc-700 text-white focus:outline-none focus:ring-2 focus:ring-blue-500"
      />
    </div>

    <div id="post-list" class="flex flex-col gap-6">
      {posts.map((post) => (
        <article class="post-item bg-zinc-900/50 p-6 rounded-xl border border-zinc-800 flex flex-col gap-2 transition-all hover:border-zinc-600">
          <h2 class="text-xl font-bold text-white">{post.data.title}</h2>
          <time class="text-sm text-zinc-400">
            {post.data.pubDate.toLocaleDateString('ja-JP')}
          </time>
          <p class="text-zinc-300 text-sm line-clamp-1">
            {post.data.description}
          </p>
          <div class="mt-2">
            <a 
              href={post.id} 
              target="_blank" 
              class="inline-block bg-white text-black px-4 py-1.5 rounded-full text-sm font-medium hover:bg-zinc-200 transition-colors"
            >
              Read more
            </a>
          </div>
        </article>
      ))}
    </div>
  </main>
</Layout>

<script>
  const searchBar = document.getElementById('search-bar') as HTMLInputElement;
  const postItems = document.querySelectorAll('.post-item');

  searchBar?.addEventListener('input', (e) => {
    const searchTerm = (e.target as HTMLInputElement).value.toLowerCase();

    postItems.forEach((item) => {
      const title = item.querySelector('h2')?.textContent?.toLowerCase() || "";
      const description = item.querySelector('p')?.textContent?.toLowerCase() || "";
      
      if (title.includes(searchTerm) || description.includes(searchTerm)) {
        (item as HTMLElement).style.display = 'flex';
      } else {
        (item as HTMLElement).style.display = 'none';
      }
    });
  });
</script>