<main class="max-w-4xl mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold mb-8 text-zinc-900 dark:text-white">Blog Posts</h1>

    <div class="mb-10">
      <input 
        type="text" 
        id="search-bar" 
        placeholder="Search posts..." 
        class="w-full p-3 rounded-lg bg-white dark:bg-zinc-900 border border-zinc-300 dark:border-zinc-700 text-zinc-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-blue-500 transition-colors"
      />
    </div>

    <div id="post-list" class="grid grid-cols-1 gap-6">
      {posts.map((post) => (
        <div class="post-item">
          <BlogPostCard
            slug={post.id}
            title={post.data.title}
            excerpt={post.data.description}
            date={post.data.pubDate}
            image={post.data.image}
          />
        </div>
      ))}
    </div>
  </main>
</Layout>

<script>
  document.addEventListener('astro:page-load', () => {
    const searchBar = document.getElementById('search-bar') as HTMLInputElement;
    const postItems = document.querySelectorAll('.post-item');

    searchBar?.addEventListener('input', (e) => {
      const searchTerm = (e.target as HTMLInputElement).value.toLowerCase();

      postItems.forEach((item) => {
        const title = item.querySelector('h4')?.textContent?.toLowerCase() || "";
        const description = item.querySelector('p')?.textContent?.toLowerCase() || "";
        
        if (title.includes(searchTerm) || description.includes(searchTerm)) {
          (item as HTMLElement).style.display = 'flex';
        } else {
          (item as HTMLElement).style.display = 'none';
        }
      });
    });
  });
</script>