---
import { getCollection } from "astro:content";
import Hero from "@/components/Hero.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Section from "@/components/Section.astro";
import BlogPostCard from "@/components/BlogPostCard.astro";
import Layout from "@/layouts/Layout.astro";
import { KNOWN_TECH, ABOUT_ME, QUOTE } from "@/consts";
import WorksList from "@/components/WorksList.astro";
import Parser from "rss-parser";
import { Image } from "astro:assets";
//import risajuIcon from "@/assets/risaju.png";
import twitterIcon from "@/assets/Logo_of_Twitter.svg.png";
import noteIcon from "@/assets/Logo_of_Note.svg";
import powerpcIcon from "@/assets/PowerPC_icon.png";
import csharpIcon from "@/assets/csharp-logo.svg";
import whitespaceCode from "@/whitespace.ws?raw";

/*
const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
*/

// 記事データの型を定義
interface NotePost {
  id: string;
  data: {
    title: string;
    description: string;
    pubDate: Date;
    image?: string;
  };
}

const parser = new Parser();
const NOTE_RSS_URL = "https://note.com/np7096/rss";

let posts: NotePost[] = [];


try {
  const feed = await parser.parseURL(NOTE_RSS_URL);
  posts = feed.items
    .filter(item => item.link && item.title && item.pubDate)
    .map(item => ({
      id: item.link!, // noteの記事URL
      data: {
        title: item.title!,
        description: item.contentSnippet?.slice(0, 100) + "...", // 冒頭100文字
        pubDate: new Date(item.pubDate!),
        image: item.enclosure?.url,
      }
    }));
} catch (error) {
  console.error("noteのデータ取得に失敗しました:", error);
}

const socialLinks = [
  // 重複を削除し、インポートした変数(twitterIconなど)のみを使う
  { name: "Daily", url: "https://x.com/Np27182", icon: twitterIcon },
  { name: "Tech", url: "https://x.com/Np271828", icon: twitterIcon },
  { name: "MUGEN", url: "https://x.com/np_mugen", icon: twitterIcon },
  { name: "GitHub", url: "https://github.com/enupi", icon: "github" },
  { name: "Note", url: "https://note.com/np7096", icon: noteIcon },
  { name: "Osu!", url: "https://osu.ppy.sh/users/27981771", icon: "osu"},
];

const mutualLinks = [
  { name: "まだ誰もいないよ", url: "#" },
  { name: "hogehoge", url: "#" },
  { name: "gehogeho", url: "#" },
  

];

// Simple Iconsのスラッグ調整用マップ
const techIconMap: Record<string, any> = {
  "Javascript": "javascript",
  "Typescript": "typescript",
  "CSS": "css",
  "HTML5": "html5",
  "C++": "cplusplus",
  "C#": csharpIcon,
  "PowerPC": powerpcIcon,
};



// 重複を除去
const uniqueTech = [...new Set(KNOWN_TECH.map(t => t.trim()))];

const aboutMeCards = [
  { 
    title: "What am I ?", 
    description: [
      "電気通信大学 情報理工学域 Ⅰ類の Np / えぬぴーです。",
      "Switch 向けの Homebrew 開発と M.U.G.E.N のキャラクター制作をしています。",
      "最近は Arch の Ricingとこのサイトに使っている Astro を始めて両方の沼に沈んでいるところです。",
      "blender も勉強中です。今はアニメキャラを作ってます。",
      "いろんなものを作っていきたいです (ovo)"
    ]
  },
  {
    title: "My Faves",
    hobbies: [
      { label: "Game", value: "Osu!, SOUND VOLTEX, Beatmania IIDX, アークナイツ：エンドフィールド, SPLATOON (無印〜3), M.U.G.E.N" },
      { label: "Artist", value: "Yunomi, somunia, EmoCosine, かたぎり, かぼちゃ, かねこちはる, Halv,  ..." },
      { label: "Misc", value: "アニメ〜〜🤞" },
    ]
  },
  { title: "Languages I Use", tech: uniqueTech },
  //{ title: "PC環境", content: "Windows Desktop (自作) / MacBook Air" },

  //{ title: "書きそうな記事の分野", content: "技術備忘録, M.U.G.E.N 開発進捗, 大学生活" },
  { title: "Contact", content: '重要な連絡は Twitter (<a href="https://x.com/Np271828" target="_blank" rel="noopener noreferrer" class="text-blue-400 underline underline-offset-4 hover:text-blue-300 transition-colors">@Np271828</a>) のDMにお願いします' },
  { title: "こんなところに丁度いい余白が...?", content: `<div class="w-full bg-zinc-100 dark:bg-zinc-800/50 p-4 rounded-lg border border-zinc-200 dark:border-zinc-700 overflow-x-auto"><pre class="text-xs text-zinc-600 dark:text-zinc-300"><code>${whitespaceCode}</code></pre></div>` },
];

---

<Layout title="Np's pages">
  <div class="relative">
    <Hero />
  </div>

  <div class="w-full bg-zinc-50 dark:bg-black py-10 border-y border-zinc-200 dark:border-zinc-900/50 transition-colors">
    <div class="max-w-6xl mx-auto px-6 flex justify-center gap-8 md:gap-16">
      {
        socialLinks.map((link) => (
          <a
            href={link.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group flex flex-col items-center gap-3 transition-all"
          >
            <div class="p-4 bg-white dark:bg-zinc-900/50 border border-zinc-200 dark:border-zinc-800 rounded-2xl group-hover:border-blue-400 group-hover:bg-zinc-100 dark:group-hover:bg-zinc-800 group-hover:-translate-y-1 transition-all duration-300 flex items-center justify-center shadow-sm dark:shadow-none">
              {typeof link.icon === 'string' ? (
                <img
                  src={link.icon.startsWith("/") ? link.icon : `https://cdn.simpleicons.org/${link.icon}/white`}
                  alt={link.name}
                  class={`w-8 h-8 md:w-10 md:h-10 opacity-70 group-hover:opacity-100 transition-opacity object-contain ${link.icon.startsWith("/") ? "brightness-0 dark:invert" : "invert dark:invert-0"}`}
                />
              ) : (
                <Image
                  src={link.icon}
                  alt={link.name}
                  class="w-8 h-8 md:w-10 md:h-10 opacity-70 group-hover:opacity-100 transition-opacity object-contain brightness-0 dark:invert"
                />
              )}
            </div>
            <span class="text-[10px] md:text-xs text-zinc-500 font-bold uppercase tracking-[0.2em] group-hover:text-blue-400 transition-colors">
              {link.name}
            </span>
          </a>
        ))
      }
    </div>
  </div>

  <Section
    title="New Posts"
    className={"bg-zinc-50 dark:bg-black transition-colors"}
  >
    <div class="w-full grid grid-cols-1 md:grid-cols-2 gap-4">
      {
        posts.map((post) => (
          <BlogPostCard
            slug={post.id}
            title={post.data.title}
            excerpt={post.data.description}
            date={post.data.pubDate}
            image={post.data.image}
          />
        ))
      }
    </div>
    <div class="mt-8 text-center">
      <a href="/blog"
         class="inline-flex items-center px-6 py-3 border border-blue-400 text-blue-400 font-bold uppercase tracking-widest rounded-md hover:bg-blue-400 hover:text-black transition-colors duration-300">
        View All Notes
        <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
        </svg>
      </a>
    </div>
  </Section>
  
  <Section
    title="Works"
    id="work"
  >
    <WorksList />
  </Section>
  
  <Section
  title="Links"
  id="link"
  >
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">
      {
        mutualLinks.map((link) => (
          <a
            href={link.url}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center justify-center p-6 bg-white dark:bg-zinc-900/50 border border-zinc-200 dark:border-zinc-800 rounded-xl transition-all hover:border-blue-400 dark:hover:border-zinc-600 hover:bg-zinc-50 dark:hover:bg-zinc-900 group shadow-sm dark:shadow-none"
          >
            <span class="text-lg text-zinc-500 dark:text-zinc-400 group-hover:text-blue-500 dark:group-hover:text-white font-medium transition-colors">
              {link.name}
            </span>
          </a>
        ))
      }
    </div>
  </Section>

  <Section title="About Me" id="about">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 items-start">
      {
        aboutMeCards.map((item) => (
          <div class:list={[
            "p-6 bg-white dark:bg-zinc-900/50 border border-zinc-200 dark:border-zinc-800 rounded-xl transition-all hover:border-blue-400 dark:hover:border-zinc-700 shadow-sm dark:shadow-none",
            { "md:col-span-2": item.title === "What am I ?" || item.title === "Contact" || item.title === "こんなところに丁度いい余白が...?" }
          ]}>
            <h3 class="text-blue-400 font-bold mb-4 text-xl uppercase tracking-widest border-b border-zinc-800 pb-2">
              {item.title}
            </h3>
            {item.tech ? (
              <div class="flex flex-wrap gap-4">
                {item.tech.map((name) => {
                  const iconData = techIconMap[name] || name.toLowerCase();
              const isCsharp = name === "C#";
                  return typeof iconData === "string" ? (
                    <img
                      src={iconData.startsWith("/") ? iconData : `https://cdn.simpleicons.org/${iconData}/white`}
                      alt={name}
                      title={name}
                  class={`w-14 h-14 opacity-70 hover:opacity-100 transition-opacity ${iconData.startsWith("/") ? (isCsharp ? "grayscale dark:invert" : "brightness-0 dark:invert") : "invert dark:invert-0"}`}
                    />
                  ) : (
                    <Image
                      src={iconData}
                      alt={name}
                      title={name}
                      width={56}
                      height={56}
                  class={`w-14 h-14 opacity-70 hover:opacity-100 transition-opacity ${isCsharp ? "grayscale dark:invert" : "brightness-0 dark:invert"}`}
                    />
                  );
                })}
              </div>
            ) : item.hobbies ? (
              <div class="space-y-3 text-base text-zinc-600 dark:text-zinc-300">
                {item.hobbies.map((hobby) => (
                  <div>
                    <span class="block text-base text-blue-300/100 font-bold uppercase tracking-tighter mb-1">{hobby.label}</span>
                    <span class="text-base leading-relaxed">{hobby.value}</span>
                  </div>
                ))}
              </div>
            ) : item.description ? (
              <div class="space-y-2 text-zinc-600 dark:text-zinc-300 text-base leading-relaxed">
                {item.description.map((line) => <p>{line}</p>)}
              </div>
            ) : (
              <div class="text-zinc-600 dark:text-zinc-300 text-base leading-relaxed w-full" set:html={item.content}></div>
            )}
          </div>
        ))
      }
    </div>
  </Section>
<!--
  <Section title="Technologies I Know" full_screen={false}>
    <div class="w-full grid place-items-center">
      <div
        class="w-full gap-4 flex flex-wrap px-3 max-w-xl text-lg justify-center"
      >
        {KNOWN_TECH.map((x) => <Breadcrumb title={x} />)}
      </div>
    </div>
  </Section>

  <Section title="About Me">
    <div class="w-full grid place-items-center">
      <div
        class="max-w-4xl text-xl md:text-lg opacity-90 text-center justify-evenly"
      >
        <p>{ABOUT_ME}</p>
      </div>
    </div>
  </Section>
-->
</Layout>

<style is:global>
  html {
    scroll-behavior: smooth;
  }
  /* アンカーリンクでスクロールした際、ヘッダーに隠れないように位置を調整 */
  #work, #link, #about {
    scroll-margin-top: 5rem;
  }
</style>
